<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/photoImageView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:contentDescription="Photo"/>

    <TextView
        android:id="@+id/photoNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:paddingVertical="8dp"/>

    <TextView
        android:id="@+id/tagsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnPrev"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="← Prev"/>
        <Button android:id="@+id/btnNext"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Next →"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnAddTag"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Add Tag"/>
        <Button android:id="@+id/btnDeleteTag"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Del Tag"/>
        <Button android:id="@+id/btnMove"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Move"/>
    </LinearLayout>
</LinearLayout>